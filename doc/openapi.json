{
  "openapi": "3.0.3",
  "info": {
    "title": "myapp",
    "version": "1.0.0"
  },
  "servers": [

  ],
  "paths": {
    "/bands": {
      "post": {
        "summary": "create",
        "tags": [
          "Band"
        ],
        "parameters": [
          {
            "name": "band",
            "in": "query",
            "schema": {
              "type": "object",
              "properties": {
                "bookmarks_count": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            },
            "example": {
              "bookmarks_count": "1",
              "name": "Bon Jovi"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "creates a new Band",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "id": 475,
                  "name": "Janis Joplin and Big Brother and the Holding Company"
                }
              }
            }
          }
        }
      }
    },
    "/albums": {
      "post": {
        "summary": "create",
        "tags": [
          "Album"
        ],
        "parameters": [
          {
            "name": "album",
            "in": "query",
            "schema": {
              "type": "object",
              "properties": {
                "bookmarks_count": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              }
            },
            "example": {
              "bookmarks_count": "1",
              "title": "Midnight Memories"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "creates a new Album",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "title": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "id": 20,
                  "title": "Gold: Greatest Hits"
                }
              }
            }
          }
        }
      }
    },
    "/artists": {
      "post": {
        "summary": "create",
        "tags": [
          "Artist"
        ],
        "parameters": [
          {
            "name": "artist",
            "in": "query",
            "schema": {
              "type": "object",
              "properties": {
                "bookmarks_count": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            },
            "example": {
              "bookmarks_count": "1",
              "name": "MyString"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "creates a new Artist",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "id": 20,
                  "name": "MyString"
                }
              }
            }
          }
        }
      }
    },
    "/musics": {
      "post": {
        "summary": "create",
        "tags": [
          "Music"
        ],
        "parameters": [
          {
            "name": "music",
            "in": "query",
            "schema": {
              "type": "object",
              "properties": {
                "band": {
                  "type": "string"
                },
                "bookmarks_count": {
                  "type": "string"
                },
                "score": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "user": {
                  "type": "string"
                }
              }
            },
            "example": {
              "band": "",
              "bookmarks_count": "1",
              "score": "MyString",
              "title": "For What It's Worth",
              "user": ""
            }
          }
        ],
        "responses": {
          "201": {
            "description": "creates a new Music",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "title": {
                      "type": "string"
                    },
                    "user": {
                      "nullable": true
                    }
                  }
                },
                "example": {
                  "id": 181,
                  "title": "Bad Company",
                  "user": null
                }
              }
            }
          }
        }
      }
    },
    "/musics/{id}": {
      "patch": {
        "summary": "update",
        "tags": [
          "Music"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 171
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "music": {
                    "type": "object",
                    "properties": {
                      "user": {
                        "nullable": true
                      },
                      "band": {
                        "nullable": true
                      },
                      "title": {
                        "type": "string"
                      },
                      "bookmarks_count": {
                        "type": "string"
                      },
                      "score": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "example": {
                "music": {
                  "user": null,
                  "band": null,
                  "title": "Satisfaction",
                  "bookmarks_count": "1",
                  "score": "MyString"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "creates a new Music",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "title": {
                      "type": "string"
                    },
                    "user": {
                      "nullable": true
                    }
                  }
                },
                "example": {
                  "id": 182,
                  "title": "Satisfaction",
                  "user": null
                }
              }
            }
          }
        }
      }
    }
  }
}
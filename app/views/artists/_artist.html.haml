%div{:id => "#{dom_id artist}"}
  %p.my-5
    %strong.block.font-medium.mb-1 Name:
    = artist.name
  %p.my-5
    %strong.block.font-medium.mb-1 Bookmarks count:
    = artist.bookmarks_count
  - if action_name != "show"
    = link_to "Show this artist", artist, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium"
    = link_to 'Edit this artist', edit_artist_path(artist), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium"
    %hr.mt-6/

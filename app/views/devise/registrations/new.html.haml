- label_class = "block text-sm font-medium text-gray-700"
- field_class = "mt-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md"

= render "devise/shared/sign_form_layout" do
  = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
    = render "devise/shared/error_messages", resource: resource
    .pb-5
      = f.label :email, class: label_class
      = f.email_field :email, autofocus: true, autocomplete: "email", class: field_class
    .pb-5
      = f.label :nickname, class: label_class
      = f.text_field :nickname, autofocus: true, autocomplete: "nickname", class: field_class
    .pb-5.grid.grid-cols-2.gap-6
      .group
        = f.label :familyname, class: label_class
        = f.text_field :familyname, autofocus: true, autocomplete: "family-name", class: field_class
      .group
        = f.label :givenname, class: label_class
        = f.text_field :givenname, autofocus: true, autocomplete: "given-name", class: field_class
    .pb-5
      = f.label :password, class: label_class 
      - if @minimum_password_length
        %em
          (#{@minimum_password_length} characters minimum)
      = f.password_field :password, autocomplete: "new-password", class: field_class
    .pb-5
      = f.label :password_confirmation, class: label_class 
      = f.password_field :password_confirmation, autocomplete: "new-password", class: field_class
    .pb-5
      = f.submit "Sign up", class: "group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"

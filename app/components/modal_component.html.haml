.inline{"data-controller": "dropdown"}
	%button.block{ type: "button", "data-action": "dropdown#toggle"}
		= icon 
	.flex.justify-center.items-center.absolute.z-10.inset-0.hidden.transition.transform{ class: "bg-black/50 h-[100vh] w-[100vw]", "data-action": "click->dropdown#toggle", "data-dropdown-target" => "menu", "data-transition-enter-from" => "opacity-0", "data-transition-enter-to" => "opacity-100", "data-transition-leave-from" => "opacity-100", "data-transition-leave-to" => "opacity-0"}
		.bg-white.p-5{ "onclick": "event.stopPropagation()" }
			= content
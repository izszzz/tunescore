%h1 Listing musics

%table
  %thead
    %tr
      %th User
      %th Band
      %th Title
      %th Bookmarks count
      %th Score
      %th
      %th
      %th

  %tbody
    - @musics.each do |music|
      %tr
        %td= music.user
        %td= music.band
        %td= music.title
        %td= music.bookmarks_count
        %td= music.score
        %td= link_to 'Show', music
        %td= link_to 'Edit', edit_music_path(music)
        %td= link_to 'Destroy', music, method: :delete, data: { confirm: 'Are you sure?' }

%br

= link_to 'New Music', new_music_path

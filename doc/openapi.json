{
  "openapi": "3.0.3",
  "info": {
    "title": "myapp",
    "version": "1.0.0"
  },
  "servers": [

  ],
  "paths": {
    "/bands": {
      "post": {
        "summary": "create",
        "tags": [
          "Band"
        ],
        "parameters": [
          {
            "name": "band",
            "in": "query",
            "schema": {
              "type": "object",
              "properties": {
                "bookmarks_count": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            },
            "example": {
              "bookmarks_count": "1",
              "name": "Bon Jovi"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "creates a new Band",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "id": 445,
                  "name": "Bon Jovi"
                }
              }
            }
          }
        }
      }
    }
  }
}
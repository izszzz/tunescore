= form_with(model: resource, class: "contents") do |form|
  - if resource.errors.any?
    #error_explanation.bg-red-50.text-red-500.px-3.py-2.font-medium.rounded-lg.mt-3
      %h2
        = pluralize(resource.errors.count, "error")
        prohibited this resource from being saved:
      %ul
        - resource.errors.each do |error|
          %li= error.full_message
  .my-5
    = form.label label
    = form.text_field label, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full"
  = yield form
  .inline
    = form.submit class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer"